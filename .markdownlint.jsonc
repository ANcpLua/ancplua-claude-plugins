{
  // ancplua-claude-plugins markdownlint configuration
  // Agent prompts, skills, commands are excluded via .markdownlintignore
  // This config only applies to actual documentation (README, CLAUDE.md, docs/)
  "default": true,

  // MD013: Line length — 120 for prose, relaxed for code/tables/headings
  "MD013": {
    "line_length": 120,
    "heading_line_length": 120,
    "code_block_line_length": 200,
    "code_blocks": false,
    "tables": false,
    "headings": false
  },

  // MD024: Duplicate headings — allowed under different parents (CHANGELOG pattern)
  "MD024": {
    "siblings_only": true
  },

  // MD004: Unordered list style — dashes
  "MD004": {
    "style": "dash"
  },

  // MD029: Ordered list prefix — sequential (1/2/3)
  "MD029": {
    "style": "ordered"
  },

  // MD033: Inline HTML — disabled (CLAUDE.md uses XML tags for emphasis)
  "MD033": false,

  // MD041: First line heading — disabled (YAML frontmatter)
  "MD041": false,

  // MD050: Strong style — asterisks
  "MD050": {
    "style": "asterisk"
  },

  // MD060: Table column style — disabled
  "MD060": false
}
