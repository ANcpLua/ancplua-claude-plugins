{
  // ancplua-claude-plugins markdownlint configuration
  // Merged from .markdownlint.json + .markdownlint.jsonc (was split across two files)
  "default": true,

  // MD013: Line length — 120 for prose, relaxed for code/tables/headings
  "MD013": {
    "line_length": 120,
    "heading_line_length": 120,
    "code_block_line_length": 200,
    "code_blocks": false,
    "tables": false,
    "headings": false
  },

  // MD007: Unordered list indent — 2 spaces
  "MD007": {
    "indent": 2
  },

  // MD024: Duplicate headings — allowed under different parents (CHANGELOG pattern)
  "MD024": {
    "siblings_only": true
  },

  // MD004: Unordered list style — dashes
  "MD004": {
    "style": "dash"
  },

  // MD029: Ordered list prefix — sequential (1/2/3)
  "MD029": {
    "style": "ordered"
  },

  // MD033: Inline HTML — disabled (Claude plugin files use XML tags extensively)
  "MD033": false,

  // MD041: First line heading — disabled (files have YAML frontmatter)
  "MD041": false,

  // MD046: Code fence style — fenced (not indented)
  "MD046": {
    "style": "fenced"
  },

  // MD050: Strong style — asterisks
  "MD050": {
    "style": "asterisk"
  },

  // MD060: Table column style — disabled (too noisy for mixed table formats)
  "MD060": false
}
