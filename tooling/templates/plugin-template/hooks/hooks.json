{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/example-check",
            "timeout": 5,
            "statusMessage": "Running example check..."
          }
        ]
      }
    ]
  }
}
