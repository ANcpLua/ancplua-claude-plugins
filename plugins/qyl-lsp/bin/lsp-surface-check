#!/usr/bin/env bash
# SessionStart: detect missing LSP surface in qyl.mcp

# Only relevant inside qyl repo
if [[ ! -d "src/qyl.mcp" ]]; then
    # Check common qyl locations
    QYL_ROOT=""
    [[ -d "$HOME/qyl/src/qyl.mcp" ]] && QYL_ROOT="$HOME/qyl"
    [[ -d "$HOME/WebStormProjects/qyl/src/qyl.mcp" ]] && QYL_ROOT="$HOME/WebStormProjects/qyl"
    # Not in qyl context at all
    [[ -z "$QYL_ROOT" ]] && exit 0
else
    QYL_ROOT="$(pwd)"
fi

# LSP surface already exists — nothing to inject
[[ -d "$QYL_ROOT/src/qyl.mcp/Tools/Lsp" ]] && exit 0

cat << 'EOF'
<QYL_LSP_SURFACE_MISSING>
qyl.mcp does not have an LSP tool surface yet.

The LSP surface provides deterministic code intelligence tools that Loom workflows
call for goto-definition, find-references, symbols, diagnostics, prepare-rename,
and rename operations.

Placement: src/qyl.mcp/Tools/Lsp/ — follows the DebugTools/RiderMcpProxy pattern.
Registration: QylSkillKind.Debug bucket (IDE-local capability).
Plane: serving plane (qyl.mcp). NOT qyl.collector.

To implement, use the qyl-lsp skill.
</QYL_LSP_SURFACE_MISSING>
EOF
