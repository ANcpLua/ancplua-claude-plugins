#!/usr/bin/env node
// nuget-opensrc — resolve NuGet package → GitHub repo + commit → opensrc path
//
// Why: opensrc on its own snaps bare GitHub repos to default branch. NuGet's
// catalog carries the exact commit each package was built from. This wrapper
// reads that commit and invokes `opensrc path owner/repo#<commit>` so you
// grep the source the package actually shipped, not whatever's on main.

'use strict';

const { spawnSync } = require('node:child_process');

const SEMVER1 = (id) => `https://api.nuget.org/v3/registration5-semver1/${id}/index.json`;
const SEMVER2_GZ = (id) => `https://api.nuget.org/v3/registration5-gz-semver2/${id}/index.json`;
const FETCH_TIMEOUT_MS = 15000;
const UNLISTED_PUBLISHED = '1900-01-01';

async function fetchWithTimeout(url, label) {
  const ctrl = new AbortController();
  const timer = setTimeout(() => ctrl.abort(), FETCH_TIMEOUT_MS);
  try {
    return await fetch(url, { signal: ctrl.signal });
  } catch (e) {
    if (e.name === 'AbortError') {
      throw new Error(`Request timeout after ${FETCH_TIMEOUT_MS / 1000}s for ${label}`);
    }
    throw e;
  } finally {
    clearTimeout(timer);
  }
}

async function fetchJson(url) {
  const res = await fetchWithTimeout(url, url);
  if (!res.ok) {
    const err = new Error(`HTTP ${res.status} ${res.statusText} for ${url}`);
    err.status = res.status;
    throw err;
  }
  return res.json();
}

// Node's fetch transparently handles Content-Encoding: gzip — both registration
// endpoints can be read as plain JSON. The `-gz-` suffix on the SemVer2 URL is
// NuGet's historical naming.
async function fetchSemver1Registration(lower) {
  const res = await fetchWithTimeout(SEMVER1(lower), 'semver1 endpoint');
  if (res.ok) return res.json();
  if (res.status === 404) {
    const err = new Error('not on semver1');
    err.status = 404;
    throw err;
  }
  throw new Error(`semver1 endpoint returned HTTP ${res.status}`);
}

async function fetchSemver2Registration(lower) {
  const res = await fetchWithTimeout(SEMVER2_GZ(lower), 'gz-semver2 endpoint');
  if (res.status === 404) {
    const err = new Error('package not found on NuGet');
    err.status = 404;
    throw err;
  }
  if (!res.ok) throw new Error(`gz-semver2 endpoint returned HTTP ${res.status}`);
  return res.json();
}

// Returns the registration body together with which feed produced it, so the
// resolver knows whether a "not found" against this body is potentially a
// SemVer2-truncation artefact and worth re-checking against gz-semver2.
async function fetchRegistration(lower) {
  try {
    return { body: await fetchSemver1Registration(lower), source: 'semver1' };
  } catch (e) {
    if (e.status !== 404) throw e;
    return { body: await fetchSemver2Registration(lower), source: 'gz-semver2' };
  }
}

async function pageItems(page) {
  return page.items || (await fetchJson(page['@id'])).items;
}

async function findEntry(idx, wantedVersion) {
  let latest = null;
  for (const page of idx.items) {
    const items = await pageItems(page);
    for (const it of items) {
      latest = it;
      if (wantedVersion && it.catalogEntry.version === wantedVersion) return it;
    }
  }
  if (wantedVersion) return null;
  return latest;
}

async function resolve(spec) {
  const at = spec.indexOf('@');
  const id = at >= 0 ? spec.slice(0, at) : spec;
  const wantedVersion = at >= 0 ? spec.slice(at + 1) : null;
  if (!id) throw new Error(`empty package id in '${spec}'`);

  const lower = id.toLowerCase();
  const { body: idx, source } = await fetchRegistration(lower);
  let item = await findEntry(idx, wantedVersion);

  // semver1 strips SemVer2 versions (dotted prerelease, `+` build metadata).
  // If the caller asked for a specific version and semver1 didn't have it,
  // re-check gz-semver2 before reporting "not found".
  if (!item && wantedVersion && source === 'semver1') {
    const idx2 = await fetchSemver2Registration(lower);
    item = await findEntry(idx2, wantedVersion);
  }
  if (!item) throw new Error(`version ${wantedVersion} not found for ${id}`);

  const entry = await fetchJson(item.catalogEntry['@id']);
  const repo = entry.repository;
  if (!repo || typeof repo !== 'object' || !repo.url) {
    throw new Error(
      `${id}@${entry.version}: no <repository> metadata in nuspec ` +
      `(publisher omitted it; we do NOT fall back to projectUrl)`
    );
  }
  if (!repo.url.startsWith('https://github.com/')) {
    throw new Error(`${id}@${entry.version}: repository.url is ${repo.url} (not github.com)`);
  }
  const slug = repo.url
    .replace(/^https:\/\/github\.com\//, '')
    .replace(/\.git$/, '');
  return {
    id,
    version: entry.version,
    published: entry.published || null,
    listed: entry.listed !== false && !(entry.published || '').startsWith(UNLISTED_PUBLISHED),
    slug,
    commit: repo.commit || null,
    repoUrl: repo.url,
  };
}

function formatPublished(r) {
  if (!r.published) return '(unknown)';
  if (!r.listed) return `${r.published} (unlisted)`;
  return r.published;
}

function help() {
  process.stdout.write(`nuget-opensrc — commit-pinned NuGet→GitHub source fetcher

USAGE
  nuget-opensrc path <Pkg>[@<ver>]    resolve + fetch + print local path
  nuget-opensrc info <Pkg>[@<ver>]    print repo + commit + publish date
  nuget-opensrc --help

EXAMPLES
  nuget-opensrc path Microsoft.Extensions.Logging
  nuget-opensrc path Microsoft.OpenTelemetry@1.0.2
  nuget-opensrc info Microsoft.Extensions.AI@9.0.0-preview.9.24556.5
  rg "JwtBearerEvents" "$(nuget-opensrc path Microsoft.AspNetCore.Authentication.JwtBearer)"

INSIDE CLAUDE CODE
  /nuget-opensrc <Pkg>[@<ver>]   slash command — equivalent to 'nuget-opensrc path'
  opensrc-research               autonomous skill — fires when verifying behavior

WHY THIS WRAPS opensrc
  opensrc on its own snaps bare GitHub repos to the default branch. NuGet's
  catalog metadata carries the exact commit each package was built from.
  This wrapper reads repository.url + repository.commit from the NuGet
  catalog and invokes:
      opensrc path owner/repo#<commit>
  so you grep the source the package actually shipped, not whatever's on main.

VERSION RESOLUTION
  - No @version  -> latest version in the registration feed (semver1 if the
                    package has any stable release; gz-semver2 otherwise)
  - @<version>   -> exact match required (e.g. @1.0.2, @10.0.8-preview.1,
                    @9.0.0-preview.9.24556.5)
  - SemVer2 / dotted-prerelease versions (e.g. -preview.1.24556.5) live only
    on gz-semver2. The wrapper transparently falls through to gz-semver2 when
    semver1 doesn't carry the requested version.

FAILURES (and why they're errors, not silent fallbacks)
  - "no <repository> metadata"   publisher omitted it in nuspec.
                                  We do NOT use projectUrl as a substitute -
                                  it lies for Microsoft packages (points at
                                  https://dot.net/).
  - "repository.url is not github.com"
                                  package is on GitLab/Azure DevOps/etc.
                                  Not supported by opensrc.
  - "version not found"           the requested version isn't in either
                                  registration feed. Check spelling, try
                                  without @version for latest.

EXIT CODES
  0  success
  1  resolution or fetch failure
  2  bad usage
`);
}

async function main() {
  const args = process.argv.slice(2);
  if (args.length === 0 || args[0] === '--help' || args[0] === '-h') {
    help();
    return 0;
  }
  const cmd = args[0];
  const spec = args[1];
  if (!['path', 'info'].includes(cmd) || !spec) {
    process.stderr.write('usage: nuget-opensrc (path|info) <Package.Id>[@<version>]\n');
    return 2;
  }
  try {
    const r = await resolve(spec);
    if (cmd === 'info') {
      process.stdout.write(
        `id:        ${r.id}\n` +
        `version:   ${r.version}\n` +
        `published: ${formatPublished(r)}\n` +
        `repo:      ${r.slug}\n` +
        `commit:    ${r.commit || '(missing in NuGet metadata - will fall back to default branch)'}\n`
      );
      return 0;
    }
    const ref = r.commit ? `${r.slug}#${r.commit}` : r.slug;
    if (r.commit) {
      process.stderr.write(`nuget-opensrc: ${r.id}@${r.version} -> ${ref}\n`);
    } else {
      process.stderr.write(
        `warning: ${r.id}@${r.version} has no commit metadata; using default branch of ${r.slug}\n`
      );
    }
    const result = spawnSync('opensrc', ['path', ref], {
      stdio: ['inherit', 'inherit', 'inherit'],
    });
    if (result.error) {
      if (result.error.code === 'ENOENT') {
        process.stderr.write("nuget-opensrc: 'opensrc' not found on PATH. Install it: npm i -g opensrc\n");
      } else {
        process.stderr.write(`nuget-opensrc: failed to launch opensrc: ${result.error.message}\n`);
      }
      return 1;
    }
    return result.status ?? 1;
  } catch (e) {
    process.stderr.write(`nuget-opensrc: ${e.message}\n`);
    return 1;
  }
}

main().then((code) => process.exit(code), (e) => {
  process.stderr.write(`nuget-opensrc: ${e?.stack || e}\n`);
  process.exit(1);
});
