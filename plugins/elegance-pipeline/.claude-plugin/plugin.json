{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "elegance-pipeline",
  "version": "1.2.0",
  "description": "Code-elegance workflow: a multi-agent pipeline (4 scouts, 2 judges, planner, verifier, gated implementer) plus a standalone code-simplifier agent. Persistent state with stage gates.",
  "author": {
    "name": "ANcpLua",
    "url": "https://github.com/ANcpLua"
  },
  "repository": "https://github.com/ANcpLua/ancplua-claude-plugins",
  "license": "MIT",
  "keywords": [
    "elegance",
    "code-quality",
    "multi-agent",
    "refactoring",
    "pipeline",
    "scout",
    "judge",
    "simplify",
    "qyl"
  ],
  "commands": "./commands",
  "agents": [
    "./agents/elegance-scout.md",
    "./agents/elegance-judge.md",
    "./agents/elegance-planner.md",
    "./agents/elegance-verifier.md",
    "./agents/elegance-implementer.md",
    "./agents/code-simplifier.md"
  ]
}
