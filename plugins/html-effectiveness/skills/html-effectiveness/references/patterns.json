{
  "version": "1.2.0",
  "source_repo": "https://github.com/ThariqS/html-effectiveness",
  "source_author": "Thariq Shihipar (@trq212, thariq.io) — Claude Code @ Anthropic",
  "local_clone": "$HOME/.cache/thariq-html-effectiveness",
  "local_clone_branch": "main",
  "clone_if_missing": "gh repo clone ThariqS/html-effectiveness \"$HOME/.cache/thariq-html-effectiveness\"",
  "philosophy": "Markdown is linear and skim-able. HTML has layout, interaction, spatial information — you actually use it. Same content, different effectiveness. The agent produces a single self-contained .html instead of a wall of prose.",
  "triggering_principles": {
    "match_on_intent_not_phrase": "If the user describes a deliverable that would render better with layout + interaction than as markdown prose, fire — even if no listed trigger phrase appears literally. The triggers below are EXAMPLES of intent, not an exhaustive whitelist.",
    "languages": "Triggers are listed in English and German. Mixed-language input ('mach mir einen status report'), Austrian/Swiss German variants, typos, and informal contractions all count. Match by semantic intent regardless of language or case.",
    "typo_tolerance": "User typos ('reprot', 'staus', 'tirage', 'flowshart') are expected. Match by stem / phonetic similarity.",
    "case_insensitive": "Triggers are matched lower-case. 'HTML REPORT', 'html report', 'Html Report' all count.",
    "ambiguous_user_intent": "If the user says something like 'make me a thing for X', look at WHAT X is. A list of tickets → triage-board. A diff → code-review. A timeline → incident-report. Let the data shape decide the pattern.",
    "multi_pattern_fit": "If two patterns could fit, pick the one whose `key_pattern` field most closely describes the data structure the user has in hand. If still ambiguous, prefer the more interactive pattern (editor > report > diagram).",
    "be_pushy": "Default to firing when the output would otherwise be a long markdown table, several sections of prose with categories, or a list the user will sort/filter/diff. Markdown for a paragraph; HTML for anything you'll come back to.",
    "composition": "Patterns are composable. If a task naturally splits across multiple deliverables (e.g., a plan AND a spawn-deck for the plan), write multiple linked .htmls and reference each other via <a href> at the bottom. If a single pattern needs sub-work that parallelizes (audit 200 repos, scan 30 services), default to 21-agent-spawn-deck instead of one giant report.",
    "live_data_opt_in": "If the user wants live data (auto-refresh, button-click re-fetch), add a tiny localhost-only fetch() loop pointing at a Python http.server / gh cli wrapper they run alongside. Document the prerequisite in a <p class='prereq'> at the top so the artifact remains useful even when the server is off."
  },
