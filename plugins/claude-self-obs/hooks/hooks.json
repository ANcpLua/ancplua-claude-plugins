{
  "description": "claude-self-obs — POST tool call and agent lifecycle events to qyl.collector",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:5100/api/v1/claude-code/hooks",
            "timeout": 2
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:5100/api/v1/claude-code/hooks",
            "timeout": 2
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:5100/api/v1/claude-code/hooks",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
