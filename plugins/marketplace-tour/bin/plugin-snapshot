#!/usr/bin/env bash
# plugin-snapshot — deterministic plugin capability extraction.
#
# Reads truth files (CLAUDE.md/commands/agents/hooks/plugin.json) + git log and
# emits a structured JSON snapshot. Marketplace.json is read ONLY to detect
# drift — NEVER as a truth source for capability description.
#
# Usage:
#   plugin-snapshot <plugin-name>
#   plugin-snapshot all
#
# Output: JSON object (single) or JSON array (all).
# Exit: non-zero if plugin not found or required files missing.

set -euo pipefail

plugin_arg="${1:?usage: plugin-snapshot <name|all>}"
repo_root="$(git rev-parse --show-toplevel)"
marketplace="$repo_root/.claude-plugin/marketplace.json"

# jaccard_pct — token-set jaccard similarity as integer percent (0–100).
# Lowercases, splits on non-alphanumeric, drops words < 3 chars and common stopwords.
# Returns 0 if both inputs are empty / all stopwords.
jaccard_pct() {
  awk -v A="$1" -v B="$2" '
  BEGIN {
    stop = "|the|and|for|with|from|that|this|not|are|was|has|have|its|can|will|use|all|any|one|into|per|via|also|just|only|more|each|such|been|were|does|did|made|out|off|down|over|under|between|within|while|after|before|during|against|upon|them|they|their|your|our|his|her|but|who|how|what|when|where|why|which|than|then|some|too|very|same|own|"
    n = split(tolower(A), wa, /[^a-z0-9]+/)
    m = split(tolower(B), wb, /[^a-z0-9]+/)
    for (i=1; i<=n; i++) {
      w = wa[i]
      if (length(w) < 3) continue
      if (index(stop, "|" w "|") > 0) continue
      set_a[w] = 1
    }
    for (i=1; i<=m; i++) {
      w = wb[i]
      if (length(w) < 3) continue
      if (index(stop, "|" w "|") > 0) continue
      set_b[w] = 1
    }
    inter = 0; union = 0
    for (w in set_a) { union++; if (w in set_b) inter++ }
    for (w in set_b) { if (!(w in set_a)) union++ }
    if (union == 0) { print 0; exit }
    printf "%d\n", (inter * 100) / union
  }'
}

snapshot_one() {
  local name="$1"
  local dir="$repo_root/plugins/$name"
  [ -d "$dir" ] || { echo "error: plugins/$name not found" >&2; return 1; }

  local plugin_json="$dir/.claude-plugin/plugin.json"
  [ -f "$plugin_json" ] || { echo "error: $name has no .claude-plugin/plugin.json" >&2; return 1; }

  local version description keywords
  version=$(jq -r '.version // "unknown"' "$plugin_json")
  description=$(jq -r '.description // ""' "$plugin_json")
  keywords=$(jq -c '.keywords // []' "$plugin_json")

  local truth_source truth_identity=""
  local truth_file=""
  if [ -f "$dir/CLAUDE.md" ]; then
    truth_source="plugins/$name/CLAUDE.md"
    truth_file="$dir/CLAUDE.md"
  elif [ -f "$dir/README.md" ]; then
    truth_source="plugins/$name/README.md"
    truth_file="$dir/README.md"
  else
    truth_source="plugins/$name/.claude-plugin/plugin.json"
  fi
  if [ -n "$truth_file" ]; then
    # first non-blank line that isn't a markdown heading — the real identity prose
    truth_identity=$(awk '
      /^[^#[:space:]]/ {
        line = $0
        if (length(line) > 200) line = substr(line, 1, 200)
        print line
        exit
      }
    ' "$truth_file")
  fi
  [ -z "$truth_identity" ] && truth_identity="$description"

  local commands="[]"
  if [ -d "$dir/commands" ]; then
    commands=$(find "$dir/commands" -name '*.md' -type f 2>/dev/null \
      | while read -r f; do basename "$f" .md; done \
      | jq -R -s 'split("\n") | map(select(length > 0))')
  fi

  local agents="[]"
  if [ -d "$dir/agents" ]; then
    agents=$(find "$dir/agents" -name '*.md' -type f 2>/dev/null \
      | while read -r f; do basename "$f" .md; done \
      | jq -R -s 'split("\n") | map(select(length > 0))')
  fi

  local skills="[]"
  if [ -d "$dir/skills" ]; then
    skills=$(find "$dir/skills" -name 'SKILL.md' -type f 2>/dev/null \
      | while read -r f; do basename "$(dirname "$f")"; done \
      | jq -R -s 'split("\n") | map(select(length > 0))')
  fi

  local hooks="[]"
  if [ -f "$dir/hooks/hooks.json" ]; then
    hooks=$(jq -c '
      if .hooks and (.hooks | type == "object") then
        .hooks | keys
      elif .hooks and (.hooks | type == "array") then
        [.hooks[] | .event // .type // "unknown"]
      else
        []
      end
    ' "$dir/hooks/hooks.json" 2>/dev/null || echo '[]')
  fi

  local recent_commits
  recent_commits=$(cd "$repo_root" && git log -n 10 --since='4 weeks ago' \
    --format='%cs|%s' -- "plugins/$name/" 2>/dev/null \
    | jq -R -s '
        split("\n")
        | map(select(length > 0))
        | map(
            (split("|") | {date: .[0], subject: (.[1:] | join("|"))})
          )
      ')
  [ -z "$recent_commits" ] && recent_commits='[]'

  local mp_desc="" mp_version=""
  if [ -f "$marketplace" ]; then
    mp_desc=$(jq -r --arg n "$name" \
      '.plugins[] | select(.name == $n) | .description // ""' \
      "$marketplace" 2>/dev/null || echo "")
    mp_version=$(jq -r --arg n "$name" \
      '.plugins[] | select(.name == $n) | .version // ""' \
      "$marketplace" 2>/dev/null || echo "")
  fi

  local drift_status="UNKNOWN"
  local metadata_sync="unknown"
  local truth_overlap=0
  local mtime_delta_days=0

  if [ -z "$mp_desc" ]; then
    drift_status="MISSING"
  else
    # Layer 1: metadata sync — plugin.json description should equal marketplace.json description.
    # If they diverge, someone bumped plugin.json without syncing marketplace.json (the most common drift).
    if [ "$description" = "$mp_desc" ]; then
      metadata_sync="true"
    else
      metadata_sync="false"
    fi

    # Layer 2: content overlap — marketplace description should share meaningful tokens with CLAUDE.md first paragraph.
    # Low overlap means the description still reflects old framing even if both metadata files agree.
    if [ -n "$truth_identity" ]; then
      truth_overlap=$(jaccard_pct "$mp_desc" "$truth_identity")
    fi

    # Layer 3: mtime drift — only reported when both content checks passed.
    local mp_mtime cm_mtime
    mp_mtime=$(cd "$repo_root" && git log -1 --format=%ct -- .claude-plugin/marketplace.json 2>/dev/null || echo 0)
    cm_mtime=$(cd "$repo_root" && git log -1 --format=%ct -- "$truth_source" 2>/dev/null || echo 0)
    if [ "$cm_mtime" -gt "$mp_mtime" ] && [ "$cm_mtime" -gt 0 ]; then
      mtime_delta_days=$(( (cm_mtime - mp_mtime) / 86400 ))
    fi

    # Priority order: content beats mtime.
    if [ "$metadata_sync" = "false" ]; then
      drift_status="METADATA_DRIFT"
    elif [ "$truth_overlap" -lt 30 ]; then
      drift_status="CONTENT_DRIFT"
    elif [ "$mtime_delta_days" -gt 14 ]; then
      drift_status="STALE_${mtime_delta_days}d"
    else
      drift_status="FRESH"
    fi
  fi

  jq -n \
    --arg plugin "$name" \
    --arg version "$version" \
    --arg truth_source "$truth_source" \
    --arg truth_identity "$truth_identity" \
    --arg plugin_json_description "$description" \
    --arg marketplace_description "$mp_desc" \
    --arg marketplace_version "$mp_version" \
    --arg drift_status "$drift_status" \
    --arg metadata_sync "$metadata_sync" \
    --argjson truth_overlap "$truth_overlap" \
    --argjson mtime_delta_days "$mtime_delta_days" \
    --argjson commands "$commands" \
    --argjson agents "$agents" \
    --argjson skills "$skills" \
    --argjson hooks "$hooks" \
    --argjson recent_commits "$recent_commits" \
    --argjson keywords "$keywords" \
    '{
      plugin: $plugin,
      version: $version,
      truth_source: $truth_source,
      truth_identity: $truth_identity,
      plugin_json_description: $plugin_json_description,
      marketplace_description: $marketplace_description,
      marketplace_version: $marketplace_version,
      drift: {
        status: $drift_status,
        metadata_sync: ($metadata_sync == "true"),
        truth_overlap_pct: $truth_overlap,
        mtime_delta_days: $mtime_delta_days
      },
      commands: $commands,
      agents: $agents,
      skills: $skills,
      hooks: $hooks,
      keywords: $keywords,
      recent_commits: $recent_commits
    }'
}

if [ "$plugin_arg" = "all" ]; then
  first=1
  printf '['
  for d in "$repo_root"/plugins/*/; do
    n=$(basename "$d")
    [ -f "$d/.claude-plugin/plugin.json" ] || continue
    if [ $first -eq 0 ]; then printf ','; fi
    snapshot_one "$n"
    first=0
  done
  printf ']'
  echo
else
  snapshot_one "$plugin_arg"
fi
