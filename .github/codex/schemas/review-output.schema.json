{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event",
    "body"
  ],
  "properties": {
    "event": {
      "type": "string",
      "enum": [
        "APPROVE",
        "REQUEST_CHANGES",
        "COMMENT"
      ]
    },
    "body": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20000
    }
  }
}
